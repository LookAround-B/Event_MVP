# Database Connection (Required - PostgreSQL for production)
DATABASE_URL="postgresql://username:password@localhost:5432/equestrian_db"

# JWT Configuration (Required - must be at least 32 characters)
JWT_SECRET="your-super-secret-key-at-least-32-characters-long-for-production"
JWT_EXPIRY="7d"

# CORS Configuration (Required - comma-separated for production)
# Example: http://localhost:3000,https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173, http://localhost:4000, http://localhost:4001"

# Environment (development, staging, production)
NODE_ENV="development"

# Google Maps API (Optional - for venue location)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"

# Application Settings
NEXT_PUBLIC_API_URL="http://localhost:3000"
APP_NAME="Equestrian Event Management"

# File Upload Configuration (in bytes)
MAX_FILE_SIZE="2097152"

# Session Configuration
SESSION_SECRET="your-session-secret-key-change-in-production"
SESSION_EXPIRY_HOURS="24"
REFRESH_TOKEN_EXPIRY_DAYS="7"

# Email Configuration (Optional - for notifications)
EMAIL_FROM="noreply@equestrian-events.app"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# Logging
LOG_LEVEL="info"

# Rate Limiting (Optional)
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_REQUESTS_PER_MINUTE="100"

# CloudStorage/CDN for file uploads (Optional)
STORAGE_PROVIDER="local"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

