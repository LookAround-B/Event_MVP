    "@tanstack/react-table": "^8.10.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "formidable": "^3.5.4",
    "google-auth-library": "^10.6.1",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.1.7",
    "papaparse": "^5.4.1",
    "quill": "^2.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "tailwindcss": "^3.3.6",
